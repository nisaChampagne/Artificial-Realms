{
  "name": "artificial-realms",
  "version": "1.0.0",
  "description": "An AI-powered Dungeons & Dragons interactive experience",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run build:watch\" \"npm run electron:dev\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --mode production",
    "build:watch": "webpack --mode development --watch",
    "electron:dev": "wait-on dist/renderer.js && electron .",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make"
  },
  "devDependencies": {
    "electron": "^33.0.0"
  },
  "author": "Artificial Realms",
  "license": "MIT",
  "build": {
    "appId": "com.artificialrealms.app",
    "productName": "Artificial Realms",
    "directories": {
      "output": "dist"
    }
  }
}
